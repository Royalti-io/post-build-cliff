<script>
  // Scrollytelling step tracker — IntersectionObserver pattern
  // Per skill: prefer IO over scroll listeners (mobile iOS fires scroll at end of momentum, not during)
  (() => {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReduced) return; // skill mandate: respect reduced-motion preference

    const steps = document.querySelectorAll<HTMLElement>('.pbc-scrolly-step');
    const frames = document.querySelectorAll<HTMLElement>('.pbc-scrolly-visual .frame');
    if (!steps.length || !frames.length) return;

    const setActive = (idx: number) => {
      steps.forEach((s, i) => s.classList.toggle('is-active', i === idx));
      frames.forEach((f, i) => f.classList.toggle('is-active', i === idx));
    };

    const io = new IntersectionObserver(
      (entries) => {
        // pick the entry closest to viewport center
        const intersecting = entries.filter((e) => e.isIntersecting);
        if (!intersecting.length) return;
        const top = intersecting.sort(
          (a, b) => Math.abs(a.boundingClientRect.top - window.innerHeight / 2)
                  - Math.abs(b.boundingClientRect.top - window.innerHeight / 2)
        )[0];
        const idx = Number((top.target as HTMLElement).dataset.step || 0);
        setActive(idx);
      },
      { threshold: [0.3, 0.5, 0.7], rootMargin: '-20% 0px -20% 0px' }
    );

    steps.forEach((s) => io.observe(s));
  })();
</script>
